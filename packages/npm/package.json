{
  "name": "@bittensormcp/sign",
  "version": "0.1.0",
  "description": "Self-custody signing helper for BittensorMCP — your private key never leaves your machine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bittensor",
    "polkadot",
    "sr25519",
    "self-custody",
    "bittensormcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimbo128/SignSDK"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
